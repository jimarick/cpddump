APP_NAME="CPD Dump"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://cpd-dump.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=cpd_dump
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# AI. Set AI_DEFAULT_PROVIDER to "anthropic" or "openai" — the default
# provider powers analysis, reflections, reports and search assist.
# Transcription (dictation, voice notes) always needs an OpenAI key.
AI_DEFAULT_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AI_DAILY_TOKEN_BUDGET=200000
AI_DAILY_INPUT_TOKEN_BUDGET=1000000
AI_PLATFORM_DAILY_TOKEN_BUDGET=10000000
AI_MAX_SCANNED_PDF_PAGES=20

# Heavy models — used for inbox analysis, ask-a-question and reports.
AI_ANTHROPIC_MODEL=claude-sonnet-5
AI_OPENAI_MODEL=gpt-5.4

# Fast models — used for sparkle text assists and the weekly digest email.
AI_ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001
AI_OPENAI_MODEL_FAST=gpt-5.4-mini

# Transcription (dictation, voice notes) always uses OpenAI regardless
# of provider, so dictation needs OPENAI_API_KEY either way.

# Resend: outbound mail + the inbound dump-address webhook (being
# replaced by SES; both webhooks coexist during the migration).
RESEND_API_KEY=
RESEND_INBOUND_WEBHOOK_SECRET=
INBOUND_EMAIL_DOMAIN=cpddump.com

# AWS SES (eu-west-2): inbound landing bucket + outbound sending.
# Deliberately not AWS_* names — Laravel Cloud injects those for R2.
SES_INBOUND_KEY=
SES_INBOUND_SECRET=
SES_INBOUND_REGION=eu-west-2
SES_INBOUND_BUCKET=
# MAIL_MAILER=ses at cutover; until then Resend keeps sending.
CPD_CONTACT_EMAIL=james.ricketts@gmail.com

# APNs push notifications for the iOS companion app. The .p8 auth key is
# never committed — point at a local file, or put the key contents in
# APNS_PRIVATE_KEY (with \n newlines) on hosts without a writable disk.
# Environment: "sandbox" for Xcode development builds, "production" for
# TestFlight/App Store builds.
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.cpddump.CPDDump
APNS_ENVIRONMENT=sandbox
APNS_PRIVATE_KEY_PATH=storage/app/apns/AuthKey.p8
APNS_PRIVATE_KEY=

# Paddle (sandbox scaffold; nothing is charged during beta).
PADDLE_SANDBOX=true
PADDLE_SELLER_ID=
PADDLE_API_KEY=
PADDLE_CLIENT_SIDE_TOKEN=
PADDLE_WEBHOOK_SECRET=

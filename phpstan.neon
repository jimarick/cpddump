includes:
    - vendor/larastan/larastan/extension.neon
    - vendor/nesbot/carbon/extension.neon

parameters:
    paths:
        - app/
        - bootstrap/app.php
        - config/
        - database/
        - routes/

    level: 7

    ignoreErrors:
        # sabre/vobject components are iterable but ship no generic
        # annotations; typehinting VEvent is correct, the library just
        # can't express its value type.
        -
            identifier: missingType.iterableValue
            path: app/Services/CalendarFeedSync.php
